{
  "identifier": "default",
  "description": "Window basics, native open/save dialogs, and text-file read/write for user documents.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "**" }] }
  ]
}
